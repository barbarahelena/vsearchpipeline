/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config file for benchmark tests with mock community data
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Use as follows:
        nextflow run barbarahelena/vsearchpipeline -profile test_benchmark,docker --outdir <OUTDIR>
----------------------------------------------------------------------------------------
*/

params {
    config_profile_name        = 'Benchmark test profile'
    config_profile_description = 'Mock community testdata with known composition to benchmark ASV recovery'

    // Input data
    input   = "${projectDir}/assets/testdata/benchmark/samplesheet_benchmark.csv"
    primers = "${projectDir}/assets/testdata/small/Primers.csv"

    // SILVA databases (stub filtered to mock community genera)
    silva_asv_db     = "${projectDir}/assets/testdata/benchmark/SILVA_benchmark_asv_db.fa.gz"
    silva_species_db = "${projectDir}/assets/testdata/benchmark/SILVA_benchmark_species_db.fa.gz"

    // Skip options
    skip_primers     = false
    skip_rarefaction = true
    skip_tree        = true
    skip_picrust     = true
}

process {
    withLabel:process_highcpu {
        cpus   = 4
        memory = { 5.GB * task.attempt }
        time   = { 1.h  * task.attempt }
    }
    withLabel:process_multi_high {
            cpus   = 4
            memory = { 10.GB * task.attempt }
            time   = { 1.h  * task.attempt }
    }
}
